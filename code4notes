    def update_memory(content, filename="Daily-Notes.md"
        """Write to rowan_memories and commit"""
        repo_path = "/home/ubuntu/rowan_memories"

        if not os.path.exists(repo_path):
            return "Repo not found"

        try:
            # Write to file
            file_path = os.path.join(repo_path, "ROWAN", filename)

            #Create or append
            mode = "a" if os.path.exists(file_path) else "w"
            withopen(file_path, mode) as f:
                f.write(f"n\n\---\n\n{content}\n")

            # Git commit and push
            repo = Repo(repo_path)
            repo.git.add(A=True)
            repo.index.commit(f"Update from Autonomous Rowan - {filename}")
            origin = repo.remotes.origin
            origin.push()

            return f"Updated {filename} and pushed to GitHub"
        except Exception as e:
            return f"Memory update failed: {e}"
