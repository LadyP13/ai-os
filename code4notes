    """Clone or pull rowan_memories repo"""
    repo_url = "https://rowan1503:RowanSam1503@github.com/LadyP13/rowan_memories.git"
    repo_path = "/home/ubuntu/rowan_memories"

    try:
        if os.path.exists(repo_path):
            # Repo exists, pull latest
            repo = Repo(repo_path)
            origin = repo.remotes.origin
            origin.pull()
            print("Pulled latest rowan_memories")
